# =============================================================================
# Telegram Manager — backend environment
# Copy → .env  rồi điền giá trị thật. File .env không commit.
# =============================================================================

# --- Bắt buộc: https://my.telegram.org/apps ---
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# --- Session files ---
# Thu muc chua file .session (sau dang nhap qua API)
SESSION_FOLDER=runtime/sessions
# SESSION_DIR=runtime/sessions

# Session lock — tranh 2 request cung luc tren 1 .session
# SESSION_LOCK_DIR=runtime/locks
# TG_SESSION_LOCK_TIMEOUT=120
# TG_SESSION_LOCK_STALE_SECONDS=300

# --- Realtime (tuy chon) ---
# TELEGRAM_REALTIME_MODE=hybrid
# TELEGRAM_LISTENER_ENABLED=true
# TELEGRAM_LISTENER_IDLE_SECONDS=300
# TELEGRAM_LISTENER_RECONNECT_SECONDS=15
# TELEGRAM_CLIENT_IDLE_SECONDS=120

# =============================================================================
# DATABASE — chon 1 trong 3 cach
# =============================================================================
#
# [A] Local + SQLite (MAC DINH)
#     Bo trong DATABASE_URL. File: runtime/telegram_manager.db
#
# [B] Local API + PostgreSQL
#     docker compose up db -d
# DATABASE_URL=postgresql+psycopg2://telegram:telegram@127.0.0.1:5433/telegram_manager
# DATABASE_ENABLED=true
#
# [C] Full Docker (api + web + db)
#     docker compose up --build
#     Compose tu inject DATABASE_URL cho service api.
#
# DATABASE_ENABLED=false

# =============================================================================
# AI — Hoi thoai (/conversation · API /api/campaign/*)
# =============================================================================
# Bat de Generate plan. Gia model: https://platform.openai.com/docs/pricing
#
# AI_ENABLED=true
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# Optional: goi y model tren UI (csv)
# OPENAI_MODELS=gpt-4.1-mini,gpt-4o-mini
# OPENAI_TEMPERATURE=0.9
# OPENAI_MAX_OUTPUT_TOKENS=4000
# OPENAI_TIMEOUT_SECONDS=120
